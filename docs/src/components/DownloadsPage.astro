---
type Locale = "en" | "zh";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale === "zh" ? "zh" : "en";

const i18n =
  locale === "zh"
    ? {
        backToDocs: "返回文档",
        switchLanguage: "English",
        pageTitle: "GPROXY 下载",
        pageDescription: "单页展示 Cloudflare Downloads 内全部二进制文件结构（latest / staging / releases）。",
        loadingManifest: "正在加载 manifest.json ...",
        searchLabel: "搜索",
        searchPlaceholder: "gproxy-linux-x86_64.zip",
        platformLabel: "平台",
        allPlatforms: "全部平台",
        archLabel: "架构",
        allArch: "全部架构",
        currentDir: "当前目录",
        detectedOs: "检测到系统",
        detectedArch: "检测到架构",
        runtimeTip: "建议先校验 SHA256 后再运行二进制。",
        recommendationTitle: "推荐下载",
        recommendationLoading: "正在根据当前设备匹配推荐包...",
        recommendationNone: "未找到匹配当前设备的构建包，请手动选择。",
        recommendationHint: "当前设备推荐：{asset}",
        tableTitle: "全部文件",
        generatedAt: "生成时间",
        filesCount: "文件数",
        pathHeader: "路径",
        downloadHeader: "下载",
        shaHeader: "SHA256",
        loadingRow: "加载中...",
        noAssets: "当前筛选条件下没有可用文件。",
        downloadBtn: "下载",
        shaBtn: "SHA256",
        recommendedBadge: "推荐",
        loadedStatus: "已从 {base} 加载全量文件清单。",
        failedStatus: "加载失败：{error}",
      }
    : {
        backToDocs: "Back to docs",
        switchLanguage: "简体中文",
        pageTitle: "GPROXY Downloads",
        pageDescription: "Single-page file tree from Cloudflare Downloads manifests (latest / staging / releases).",
        loadingManifest: "Loading manifest.json ...",
        searchLabel: "Search",
        searchPlaceholder: "gproxy-linux-x86_64.zip",
        platformLabel: "Platform",
        allPlatforms: "All platforms",
        archLabel: "Architecture",
        allArch: "All arch",
        currentDir: "Current dir",
        detectedOs: "Detected OS",
        detectedArch: "Detected arch",
        runtimeTip: "Tip: verify SHA256 before running binaries.",
        recommendationTitle: "Recommended",
        recommendationLoading: "Matching recommended package for your device...",
        recommendationNone: "No package matched your device. Please choose manually.",
        recommendationHint: "Recommended for this device: {asset}",
        tableTitle: "All Files",
        generatedAt: "Generated At",
        filesCount: "Files",
        pathHeader: "Path",
        downloadHeader: "Download",
        shaHeader: "SHA256",
        loadingRow: "Loading...",
        noAssets: "No files match current filters.",
        downloadBtn: "Download",
        shaBtn: "SHA256",
        recommendedBadge: "Recommended",
        loadedStatus: "Loaded full file manifest from {base}.",
        failedStatus: "Failed to load manifest: {error}",
      };

const pageTitle = i18n.pageTitle;
const pageDescription = i18n.pageDescription;
const downloadsBaseUrl = (import.meta.env.PUBLIC_DOWNLOADS_BASE_URL || "https://download-gproxy.leenhawk.com")
  .trim()
  .replace(/\/+$/, "");
const docsHomeHref = locale === "zh" ? "/zh-cn/" : "/";
const languageSwitchHref = locale === "zh" ? "/downloads/" : "/zh-cn/downloads/";
---

<!doctype html>
<html lang={locale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #f6f8fb;
        --fg: #111827;
        --muted: #6b7280;
        --panel: #ffffff;
        --panel-alt: #f8fafc;
        --border: #dbe3ef;
        --accent: #0f766e;
        --accent-2: #115e59;
        --chip: #ecfeff;
        --chip-fg: #155e75;
        --row-alt: rgba(17, 24, 39, 0.02);
        --row-hover: rgba(20, 184, 166, 0.1);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0b1324;
          --fg: #e5e7eb;
          --muted: #94a3b8;
          --panel: #111827;
          --panel-alt: #0f172a;
          --border: #233146;
          --accent: #2dd4bf;
          --accent-2: #14b8a6;
          --chip: #0f2b33;
          --chip-fg: #67e8f9;
          --row-alt: rgba(255, 255, 255, 0.02);
          --row-hover: rgba(45, 212, 191, 0.12);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", system-ui, -apple-system, sans-serif;
        color: var(--fg);
        background:
          radial-gradient(circle at 18% -10%, rgba(20, 184, 166, 0.18), transparent 28%),
          radial-gradient(circle at 86% 0%, rgba(14, 165, 233, 0.14), transparent 30%),
          var(--bg);
      }

      .wrap {
        max-width: 1240px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .back {
        display: inline-flex;
        margin-bottom: 0;
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 1rem;
      }

      .lang-switch {
        display: inline-flex;
        align-items: center;
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.3rem 0.7rem;
        text-decoration: none;
        color: var(--fg);
        background: var(--panel);
        font-size: 0.82rem;
        font-weight: 600;
      }

      .lang-switch:hover {
        border-color: var(--accent);
      }

      .hero {
        background: linear-gradient(140deg, rgba(15, 118, 110, 0.1), rgba(14, 165, 233, 0.08));
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 1.2rem 1.2rem 1.1rem;
        margin-bottom: 1rem;
      }

      .hero h1 {
        margin: 0 0 0.45rem;
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        letter-spacing: 0.02em;
      }

      .muted {
        margin: 0;
        color: var(--muted);
      }

      .status {
        margin-top: 0.7rem;
        font-size: 0.92rem;
        color: var(--muted);
      }

      .toolbar {
        display: grid;
        grid-template-columns: minmax(220px, 2fr) minmax(140px, 1fr) minmax(140px, 1fr) minmax(140px, 1fr);
        gap: 0.6rem;
        margin: 0 0 1rem;
      }

      @media (max-width: 980px) {
        .toolbar {
          grid-template-columns: 1fr;
        }
      }

      .field {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.55rem 0.65rem;
      }

      .field label {
        display: block;
        color: var(--muted);
        margin-bottom: 0.25rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .field input,
      .field select {
        width: 100%;
        border: 0;
        outline: none;
        background: transparent;
        color: var(--fg);
        font-size: 0.94rem;
      }

      .runtime-info {
        margin: 0 0 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid rgba(6, 182, 212, 0.24);
        border-radius: 999px;
        padding: 0.28rem 0.62rem;
        font-size: 0.8rem;
        color: var(--chip-fg);
        background: var(--chip);
      }

      .recommend {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        margin: 0 0 1rem;
        padding: 0.85rem 0.95rem;
      }

      .recommend h2 {
        margin: 0;
        font-size: 1.03rem;
      }

      .recommend-desc {
        margin: 0.35rem 0 0;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .recommend-actions {
        margin-top: 0.65rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
        padding: 0.86rem 0.95rem;
        border-bottom: 1px solid var(--border);
        background: var(--panel-alt);
      }

      .panel h2 {
        margin: 0;
        font-size: 1.08rem;
      }

      .meta {
        margin-top: 0.3rem;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .table-wrap {
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
      }

      table {
        width: max-content;
        min-width: 100%;
        border-collapse: collapse;
        table-layout: auto;
      }

      th,
      td {
        text-align: left;
        border-bottom: 1px solid var(--border);
        padding: 0.82rem 0.9rem;
        font-size: 0.88rem;
        vertical-align: top;
      }

      th {
        color: var(--muted);
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        font-size: 0.73rem;
      }

      tbody tr:last-child td {
        border-bottom: none;
      }

      tbody tr:nth-child(even) td {
        background: var(--row-alt);
      }

      tbody tr:hover td {
        background: var(--row-hover);
      }

      tr.is-recommended td {
        background: rgba(20, 184, 166, 0.12);
      }

      .asset-line {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      .folder-btn,
      .up-btn {
        border: none;
        background: transparent;
        padding: 0;
        margin: 0;
        color: var(--fg);
        font-size: 0.84rem;
        font-weight: 600;
        line-height: 1.35;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
      }

      .folder-btn:hover,
      .up-btn:hover {
        text-decoration: none;
      }

      .asset-name {
        font-weight: 600;
        font-size: 0.84rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
      }

      .asset-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid rgba(20, 184, 166, 0.35);
        background: rgba(20, 184, 166, 0.14);
        color: #0f766e;
        font-size: 0.67rem;
        font-weight: 700;
        padding: 0.08rem 0.4rem;
      }

      @media (prefers-color-scheme: dark) {
        .asset-badge {
          color: #5eead4;
        }
      }

      .cell-actions {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 7px;
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.78rem;
        padding: 0.34rem 0.62rem;
        color: var(--fg);
        background: var(--panel-alt);
      }

      a.btn,
      a.btn:visited,
      a.btn:hover,
      a.btn:active {
        color: var(--fg);
        text-decoration: none;
      }

      .btn-primary {
        color: #ffffff;
        border-color: var(--accent);
        background: linear-gradient(140deg, var(--accent), var(--accent-2));
      }

      a.btn-primary,
      a.btn-primary:visited,
      a.btn-primary:hover,
      a.btn-primary:active {
        color: #ffffff;
      }

      .btn:hover {
        filter: brightness(1.06);
      }

      @media (max-width: 980px) {
        th,
        td {
          padding: 0.68rem 0.56rem;
        }

        .btn {
          padding: 0.3rem 0.48rem;
          font-size: 0.74rem;
        }
      }

      .empty {
        color: var(--muted);
        padding: 0.85rem;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <div class="topbar">
        <a class="back" href={docsHomeHref}>{i18n.backToDocs}</a>
        <a class="lang-switch" href={languageSwitchHref}>{i18n.switchLanguage}</a>
      </div>
      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="muted">{pageDescription}</p>
        <p class="status" id="page-status">{i18n.loadingManifest}</p>
      </header>

      <section class="toolbar">
        <div class="field">
          <label for="asset-search">{i18n.searchLabel}</label>
          <input id="asset-search" type="search" placeholder={i18n.searchPlaceholder} />
        </div>
        <div class="field">
          <label for="platform-filter">{i18n.platformLabel}</label>
          <select id="platform-filter">
            <option value="all">{i18n.allPlatforms}</option>
            <option value="linux">Linux</option>
            <option value="macos">macOS</option>
            <option value="windows">Windows</option>
            <option value="android">Android</option>
          </select>
        </div>
        <div class="field">
          <label for="arch-filter">{i18n.archLabel}</label>
          <select id="arch-filter">
            <option value="all">{i18n.allArch}</option>
            <option value="x86_64">x86_64</option>
            <option value="aarch64">aarch64</option>
          </select>
        </div>
      </section>

      <section class="runtime-info" id="runtime-info"></section>

      <section class="recommend">
        <h2>{i18n.recommendationTitle}</h2>
        <p id="recommend-desc" class="recommend-desc">{i18n.recommendationLoading}</p>
        <div id="recommend-actions" class="recommend-actions"></div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <div>
            <h2>{i18n.tableTitle}</h2>
            <div class="meta">
              {i18n.generatedAt}: <strong id="generated-at">-</strong> · {i18n.filesCount}: <strong id="files-count">0</strong> · {i18n.currentDir}: <strong id="current-dir">/</strong>
            </div>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>{i18n.pathHeader}</th>
                <th>{i18n.downloadHeader}</th>
                <th>{i18n.shaHeader}</th>
              </tr>
            </thead>
            <tbody id="assets-body">
              <tr><td class="empty" colspan="3">{i18n.loadingRow}</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <script type="module" define:vars={{ downloadsBaseUrl, i18n }}>
      const statusEl = document.getElementById("page-status");
      const searchEl = document.getElementById("asset-search");
      const platformFilterEl = document.getElementById("platform-filter");
      const archFilterEl = document.getElementById("arch-filter");
      const runtimeInfoEl = document.getElementById("runtime-info");
      const recommendDescEl = document.getElementById("recommend-desc");
      const recommendActionsEl = document.getElementById("recommend-actions");
      const generatedAtEl = document.getElementById("generated-at");
      const filesCountEl = document.getElementById("files-count");
      const currentDirEl = document.getElementById("current-dir");
      const assetsBodyEl = document.getElementById("assets-body");

      const DOWNLOADS_BASE_URL = downloadsBaseUrl;
      const I18N = i18n;

      const filters = {
        q: "",
        platform: "all",
        arch: "all"
      };

      let allAssets = [];
      let recommendedAsset = null;
      let generatedAt = null;
      let currentDir = "";

      function escapeHtml(input) {
        return String(input)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function fillTemplate(template, values) {
        let output = String(template || "");
        Object.entries(values).forEach(([key, value]) => {
          output = output.replaceAll(`{${key}}`, String(value));
        });
        return output;
      }

      function parseAssetName(name) {
        const match = /^gproxy-(android|linux|macos|windows)-([a-z0-9_]+?)(-musl)?\.zip$/i.exec(
          String(name || "")
        );
        if (!match) {
          return null;
        }
        return {
          platform: match[1].toLowerCase(),
          arch: match[2].toLowerCase(),
          libc: match[3] ? "musl" : "gnu"
        };
      }

      function detectRuntime() {
        const ua = navigator.userAgent.toLowerCase();
        const platform = navigator.platform.toLowerCase();
        let os = "linux";
        if (ua.includes("android")) {
          os = "android";
        } else if (platform.includes("mac")) {
          os = "macos";
        } else if (platform.includes("win")) {
          os = "windows";
        } else if (platform.includes("linux")) {
          os = "linux";
        }

        const source = `${ua} ${platform}`;
        const arch = /aarch64|arm64|armv8/.test(source) ? "aarch64" : "x86_64";
        return { os, arch };
      }

      const runtime = detectRuntime();

      function detectScope(path) {
        if (path.startsWith("staging/")) return "staging";
        if (path.startsWith("releases/")) return "releases";
        return "latest";
      }

      function basename(path) {
        const parts = String(path || "").split("/");
        return parts[parts.length - 1] || "";
      }

      function normalizeAsset(raw) {
        const path = String(raw?.path || "");
        const url = String(raw?.url || "").trim();
        const name = String(raw?.name || basename(path));
        const resolvedPath = path || name;
        const resolvedUrl = url || `${DOWNLOADS_BASE_URL}/${resolvedPath}`;
        const shaUrl = raw?.sha256_url ? String(raw.sha256_url) : `${resolvedUrl}.sha256`;
        return {
          name,
          path: resolvedPath,
          url: resolvedUrl,
          shaUrl,
          meta: parseAssetName(name),
          scope: detectScope(resolvedPath),
        };
      }

      function buildRuntimeChips() {
        if (!runtimeInfoEl) return;
        runtimeInfoEl.innerHTML = `
          <span class="chip">${escapeHtml(I18N.detectedOs)}: <strong>${escapeHtml(runtime.os)}</strong></span>
          <span class="chip">${escapeHtml(I18N.detectedArch)}: <strong>${escapeHtml(runtime.arch)}</strong></span>
          <span class="chip">${escapeHtml(I18N.runtimeTip)}</span>
        `;
      }

      function candidateScore(asset) {
        const scopeRank = asset.scope === "latest" ? 0 : asset.scope === "staging" ? 1 : 2;
        const libcRank =
          runtime.os === "linux" && asset.meta?.libc ? (asset.meta.libc === "gnu" ? 0 : 1) : 0;
        return `${scopeRank}${libcRank}`;
      }

      function pickRecommendedAsset(assets) {
        const candidates = assets.filter(
          (asset) => asset.meta && asset.meta.platform === runtime.os && asset.meta.arch === runtime.arch
        );
        if (!candidates.length) return null;
        candidates.sort((a, b) => candidateScore(a).localeCompare(candidateScore(b)));
        return candidates[0];
      }

      function renderRecommendation() {
        if (!recommendDescEl || !recommendActionsEl) return;
        if (!recommendedAsset) {
          recommendDescEl.textContent = I18N.recommendationNone;
          recommendActionsEl.innerHTML = "";
          return;
        }

        recommendDescEl.textContent = fillTemplate(I18N.recommendationHint, {
          asset: `${recommendedAsset.path}`
        });
        recommendActionsEl.innerHTML = `
          <a class="btn btn-primary" href="${escapeHtml(recommendedAsset.url)}">${escapeHtml(I18N.downloadBtn)}</a>
          <a class="btn" href="${escapeHtml(recommendedAsset.shaUrl)}">${escapeHtml(I18N.shaBtn)}</a>
        `;
      }

      function matchesFilter(asset) {
        if (filters.platform !== "all" && asset.meta?.platform !== filters.platform) {
          return false;
        }
        if (filters.arch !== "all" && asset.meta?.arch !== filters.arch) {
          return false;
        }
        return true;
      }

      function parentDir(path) {
        const parts = String(path || "").split("/").filter(Boolean);
        if (!parts.length) return "";
        parts.pop();
        return parts.join("/");
      }

      function buildTree(assets) {
        const root = { dirs: new Map(), files: [] };
        for (const asset of assets) {
          const parts = String(asset.path || "").split("/").filter(Boolean);
          if (!parts.length) {
            root.files.push(asset);
            continue;
          }
          let node = root;
          for (let i = 0; i < parts.length; i += 1) {
            const part = parts[i];
            const isLeaf = i === parts.length - 1;
            if (isLeaf) {
              node.files.push(asset);
            } else {
              if (!node.dirs.has(part)) {
                node.dirs.set(part, { dirs: new Map(), files: [] });
              }
              node = node.dirs.get(part);
            }
          }
        }
        return root;
      }

      function getTreeNode(root, dirPath) {
        const parts = String(dirPath || "").split("/").filter(Boolean);
        let node = root;
        for (const part of parts) {
          if (!node.dirs.has(part)) return null;
          node = node.dirs.get(part);
        }
        return node;
      }

      function renderTable() {
        if (!assetsBodyEl || !filesCountEl || !generatedAtEl || !currentDirEl) return;

        const filtered = allAssets.filter(matchesFilter);
        const tree = buildTree(filtered);
        let node = getTreeNode(tree, currentDir);
        if (!node) {
          currentDir = "";
          node = tree;
        }

        currentDirEl.textContent = currentDir ? `/${currentDir}` : "/";
        generatedAtEl.textContent = generatedAt || "-";

        const dirEntries = Array.from(node.dirs.keys())
          .filter((name) => {
            const q = filters.q;
            return !q || name.toLowerCase().includes(q);
          })
          .sort((a, b) => a.localeCompare(b));

        const fileEntries = [...node.files]
          .filter((asset) => {
            const q = filters.q;
            return !q || basename(asset.path).toLowerCase().includes(q);
          })
          .sort((a, b) => basename(a.path).localeCompare(basename(b.path)));

        const visibleCount = dirEntries.length + fileEntries.length;
        filesCountEl.textContent = String(visibleCount);

        if (!visibleCount && !currentDir) {
          assetsBodyEl.innerHTML = `<tr><td class="empty" colspan="3">${escapeHtml(I18N.noAssets)}</td></tr>`;
          return;
        }

        const rows = [];

        if (currentDir) {
          rows.push(`
            <tr class="dir-row">
              <td colspan="3">
                <button type="button" class="up-btn" data-nav-up="1">..</button>
              </td>
            </tr>
          `);
        }

        for (const dirName of dirEntries) {
          const nextDir = currentDir ? `${currentDir}/${dirName}` : dirName;
          rows.push(`
            <tr class="dir-row">
              <td colspan="3">
                <button type="button" class="folder-btn" data-nav-dir="${escapeHtml(encodeURIComponent(nextDir))}">${escapeHtml(dirName)}/</button>
              </td>
            </tr>
          `);
        }

        for (const asset of fileEntries) {
          const isRecommended = recommendedAsset && asset.path === recommendedAsset.path;
          rows.push(`
            <tr class="${isRecommended ? "is-recommended" : ""}">
              <td>
                <div class="asset-line">
                  <span class="asset-name">${escapeHtml(basename(asset.path))}</span>
                  ${isRecommended ? `<span class="asset-badge">${escapeHtml(I18N.recommendedBadge)}</span>` : ""}
                </div>
              </td>
              <td>
                <div class="cell-actions">
                  <a class="btn btn-primary" href="${escapeHtml(asset.url)}">${escapeHtml(I18N.downloadBtn)}</a>
                </div>
              </td>
              <td>
                <div class="cell-actions">
                  <a class="btn" href="${escapeHtml(asset.shaUrl)}">${escapeHtml(I18N.shaBtn)}</a>
                </div>
              </td>
            </tr>
          `);
        }

        assetsBodyEl.innerHTML = rows.join("");

        assetsBodyEl.querySelectorAll("[data-nav-dir]").forEach((el) => {
          el.addEventListener("click", () => {
            const encoded = String(el.getAttribute("data-nav-dir") || "");
            currentDir = decodeURIComponent(encoded);
            renderAll();
          });
        });

        const upEl = assetsBodyEl.querySelector("[data-nav-up]");
        if (upEl) {
          upEl.addEventListener("click", () => {
            currentDir = parentDir(currentDir);
            renderAll();
          });
        }
      }

      function renderAll() {
        renderRecommendation();
        renderTable();
      }

      function resolveManifestUrl() {
        const stamp = Date.now();
        const base = String(DOWNLOADS_BASE_URL || "").replace(/\/+$/, "");
        try {
          const parsed = new URL(base);
          const normalizedPath = parsed.pathname.replace(/\/+$/, "");
          if (normalizedPath.endsWith("/downloads")) {
            const rootPath = normalizedPath.slice(0, -"/downloads".length) || "/";
            const rootManifest = new URL(parsed.origin);
            rootManifest.pathname = `${rootPath.replace(/\/+$/, "")}/manifest.json`;
            rootManifest.search = `t=${stamp}`;
            return rootManifest.toString();
          }
        } catch (_) {
          // ignore invalid DOWNLOADS_BASE_URL and use default resolution
        }
        return `${base}/manifest.json?t=${stamp}`;
      }

      async function fetchManifest() {
        const url = resolveManifestUrl();
        const response = await fetch(url, { cache: "no-store" });
        if (!response.ok) {
          throw new Error(`failed to fetch manifest: ${response.status} (${url})`);
        }
        const manifest = await response.json();
        return { manifest, url };
      }

      function bindFilters() {
        if (searchEl) {
          searchEl.addEventListener("input", () => {
            filters.q = String(searchEl.value || "").trim().toLowerCase();
            currentDir = "";
            renderAll();
          });
        }
        if (platformFilterEl) {
          platformFilterEl.addEventListener("change", () => {
            filters.platform = String(platformFilterEl.value || "all");
            currentDir = "";
            renderAll();
          });
        }
        if (archFilterEl) {
          archFilterEl.addEventListener("change", () => {
            filters.arch = String(archFilterEl.value || "all");
            currentDir = "";
            renderAll();
          });
        }
      }

      async function init() {
        buildRuntimeChips();
        bindFilters();

        const { manifest, url: manifestUrl } = await fetchManifest();
        const rawAssets = Array.isArray(manifest?.assets) ? manifest.assets : [];
        allAssets = rawAssets.map(normalizeAsset).sort((a, b) => a.path.localeCompare(b.path));
        generatedAt = String(manifest?.generated_at || "");
        recommendedAsset = pickRecommendedAsset(allAssets);
        renderAll();

        if (statusEl) {
          statusEl.textContent = fillTemplate(I18N.loadedStatus, { base: manifestUrl || DOWNLOADS_BASE_URL });
        }
      }

      init().catch((error) => {
        if (statusEl) {
          statusEl.textContent = fillTemplate(I18N.failedStatus, {
            error: String(error?.message || error)
          });
        }
      });
    </script>
  </body>
</html>
